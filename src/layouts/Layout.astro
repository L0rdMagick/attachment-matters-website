---
// src/layouts/Layout.astro
export interface Props {
	title: string;
	description: string;
	keywords?: string;
	article?: {
		publishedTime?: string;
		author?: string;
	};
}

const { title, description, keywords, article } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://familytrusttherapy.com').toString();
const ogImage = new URL('/images/parent-child-attachment-therapy-durango-co.png', 'https://familytrusttherapy.com').toString();
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={article ? "article" : "website"} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Family Trust Therapy" />
		{article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
		{article?.author && <meta property="article:author" content={article.author} />}

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- ========= NEW, COMPLETE FAVICON & MANIFEST SETUP ========= -->
		<!-- Modern browsers will prefer the SVG for its scalability -->
		<link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
		<!-- Fallback for older browsers -->
		<link rel="icon" href="/favicon.ico" sizes="any">
		<!-- A common PNG size -->
		<link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-96x96.png">
		<!-- Apple Touch Icon for iOS home screens (e.g., iPhone/iPad) -->
		<link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
		<!-- Web App Manifest for Android home screens & theme colors -->
		<link rel="manifest" href="/site.webmanifest">
		<!-- ========================================================= -->

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">

		<!-- Schema.org JSON-LD Structured Data for Local Therapy Business -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "TherapeuticServices",
				"name": "Family Trust Therapy",
				"image": "https://familytrusttherapy.com/images/parent-child-attachment-therapy-durango-co.png",
				"@id": "https://familytrusttherapy.com/#website",
				"url": "https://familytrusttherapy.com",
				"telephone": "+1-505-920-6351",
				"email": "info@familytrusttherapy.com",
				"priceRange": "$$",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Durango",
					"addressRegion": "CO",
					"postalCode": "81301",
					"addressCountry": "US"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": 37.2753,
					"longitude": -107.8801
				},
				"description": "Attachment-focused and trauma-responsive child and family therapy serving Durango, Cortez, and southwest Colorado.",
				"openingHoursSpecification": {
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": [
						"Monday",
						"Tuesday",
						"Wednesday",
						"Thursday",
						"Friday"
					],
					"opens": "09:00",
					"closes": "17:00"
				}
			}
		</script>
	</head>
	<body class="bg-brand-linen text-brand-ink font-sans antialiased text-lg leading-relaxed">
        <header class="border-b border-brand-sandstone sticky top-0 bg-brand-linen/80 backdrop-blur-sm z-50">
            <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
                
                <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity z-50">
					<img src="/images/family-trust-therapy-logo.png" alt="Family Trust Therapy Logo" class="h-14 w-14">
					<div>
						<span class="block font-serif font-bold text-xl leading-tight text-brand-ink">Family Trust</span>
						<span class="block font-serif text-lg leading-tight text-brand-ink">Therapy</span>
					</div>
				</a>
                
				<!-- Desktop Menu -->
                <ul class="hidden md:flex space-x-8 font-sans font-semibold text-sm tracking-wider uppercase">
                    <li><a href="/" class="hover:text-brand-terracotta transition-colors">Home</a></li>
                    <li><a href="/about" class="hover:text-brand-terracotta transition-colors">About</a></li>
                    <li><a href="/services" class="hover:text-brand-terracotta transition-colors">Services</a></li>
                    <li><a href="/resources" class="hover:text-brand-terracotta transition-colors">Resources</a></li>
                    <li><a href="/contact" class="hover:text-brand-terracotta transition-colors">Contact</a></li>
                </ul>

				<!-- Hamburger Button -->
				<button id="menu-toggle" class="md:hidden z-50">
					<svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
					<svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
				</button>

            </nav>
        </header>

		<!-- Mobile Menu -->
		<div id="mobile-menu" class="hidden md:hidden fixed inset-0 bg-brand-linen z-40 flex flex-col items-center justify-center">
			<ul class="flex flex-col space-y-8 text-2xl font-serif text-center">
				<li><a href="/" class="hover:text-brand-terracotta transition-colors">Home</a></li>
				<li><a href="/about" class="hover:text-brand-terracotta transition-colors">About</a></li>
				<li><a href="/services" class="hover:text-brand-terracotta transition-colors">Services</a></li>
				<li><a href="/resources" class="hover:text-brand-terracotta transition-colors">Resources</a></li>
				<li><a href="/contact" class="hover:text-brand-terracotta transition-colors">Contact</a></li>
			</ul>
		</div>

		<main>
			<slot />
		</main>

        <footer class="bg-brand-sandstone mt-24">
            <div class="container mx-auto px-6 py-12 text-center">
				<h3 class="text-lg font-bold font-serif">Family Trust Therapy</h3>
                <p class="mt-2 text-brand-ink/70 max-w-lg mx-auto text-base">"Therapeutic interventions that move at the speed of trust"</p>
                <div class="mt-6 flex flex-col items-center gap-2">
					<a href="tel:505-920-6351" class="text-lg font-semibold text-brand-moss hover:text-brand-terracotta transition-colors">(505) 920-6351</a>
					<a href="mailto:info@familytrusttherapy.com" class="text-base text-brand-moss hover:text-brand-terracotta transition-colors">info@familytrusttherapy.com</a>
					<p class="mt-8 text-xs text-brand-ink/40">&copy; {new Date().getFullYear()} Family Trust Therapy. A service of Attachment Matters, LLC.</p>
				</div>
            </div>
        </footer>

		<script>
			// Script remains the same
			const menuToggle = document.getElementById('menu-toggle');
			const mobileMenu = document.getElementById('mobile-menu');
			const hamburgerIcon = document.getElementById('hamburger-icon');
			const closeIcon = document.getElementById('close-icon');

			if (menuToggle && mobileMenu && hamburgerIcon && closeIcon) {
				menuToggle.addEventListener('click', () => {
					mobileMenu.classList.toggle('hidden');
					hamburgerIcon.classList.toggle('hidden');
					closeIcon.classList.toggle('hidden');
				});

				mobileMenu.querySelectorAll('a').forEach(link => {
					link.addEventListener('click', () => {
						mobileMenu.classList.add('hidden');
						hamburgerIcon.classList.remove('hidden');
						closeIcon.classList.add('hidden');
					});
				});
			}
		</script>
	</body>
</html>