---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Family Trust Therapy | Child & Family Therapist Durango, CO" 
	description="Specialized child and family therapy in Durango and Cortez, CO. Attachment-focused, trauma-responsive care by Genevieve Giddings, LCSW. Book a consultation."
	keywords="child therapist Durango, family therapy Durango CO, attachment therapy Cortez, child counseling southwest Colorado, trauma-responsive parenting, Genevieve Giddings">

	<!-- Hero Section -->
	<section class="container mx-auto px-6 pt-16">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<!-- Left Column: Logo and Title -->
			<div class="flex flex-col items-center text-center">
				<img src="/images/family-trust-therapy-logo.png" alt="Family Trust Therapy Logo" class="w-56 h-56">
				<h1 class="text-4xl font-serif font-bold text-brand-ink mt-6">Family Trust Therapy</h1>
				<p class="mt-4 text-brand-ink/80 text-lg">
					Professional Child & Family Therapy in Durango and Cortez, Colorado
				</p>
			</div>
			<!-- Right Column: Hero Image -->
			<div>
				<img src="/images/parent-child-attachment-therapy-durango-co.png" alt="Parent and child connecting during family therapy in Durango, CO" class="rounded-3xl shadow-2xl w-full h-full object-cover">
			</div>
		</div>
	</section>

	<!-- Content Card Section -->
	<section class="container mx-auto px-6 pt-24">
		<div class="bg-white rounded-3xl p-12 border border-brand-sandstone shadow-xl text-center max-w-4xl mx-auto">
			<h2 class="text-4xl md:text-5xl font-serif font-bold text-brand-ink leading-tight">
				Therapy that builds connection and trust.
			</h2>
			<p class="mt-6 text-xl text-brand-ink/80 max-w-2xl mx-auto">
				A warm, compassionate, and highly skilled therapy practice based in Durango, dedicated to helping families throughout Southwest Colorado build stronger bonds and navigate life's challenges with confidence.
			</p>
			<a href="/contact" class="mt-10 inline-block bg-brand-terracotta text-white font-bold text-lg py-4 px-10 rounded-full shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all">
				Book a Consultation
			</a>
		</div>
	</section>

	<!-- QUOTE SECTION -->
	<section class="container mx-auto px-6 pt-24">
		<div class="bg-white rounded-3xl p-12 border border-brand-sandstone shadow-xl flex flex-col md:flex-row gap-12 items-center max-w-5xl mx-auto">
			<!-- Image Column -->
			<div class="md:w-1/4 flex-shrink-0 text-center">
				<img src="/images/genevieve-giddings-therapist-headshot.jpg" alt="Genevieve Giddings, LCSW, child and family therapist in Durango, CO" class="w-40 h-40 rounded-full mx-auto shadow-md">
				<p class="mt-4 font-bold font-serif text-brand-ink">Genevieve Giddings, LCSW</p>
				<p class="text-sm text-brand-ink/60 leading-tight">Founder & Therapist,<br>Family Trust Therapy</p>
			</div>
			<!-- Quote Column -->
			<div class="relative w-full">
				<span class="absolute -top-6 -left-4 text-8xl font-serif text-brand-sandstone opacity-50 z-0">“</span>
				<p class="relative z-10 text-2xl font-serif text-brand-ink/90 leading-relaxed">
					I am dedicated to helping children and families heal through compassionate, attachment-focused therapy. Serving Durango, Cortez, and the surrounding communities, my goal is to help your family build secure and lasting connections.
				</p>
			</div>
		</div>
	</section>

	<!-- FEATURES SECTION -->
	<!-- CHANGE: Added mt-24 (margin-top) to create the 24-unit space. Kept py-24 for internal vertical centering. -->
	<section class="bg-brand-sandstone mt-24 py-24">
		<div class="container mx-auto px-6 text-center">
			<h2 class="text-3xl font-serif font-bold text-brand-ink">A Child-Centered, Family-Focused Approach</h2>
			<div class="mt-12 grid md:grid-cols-3 gap-12 max-w-5xl mx-auto">
				<div>
					<h3 class="text-2xl font-serif text-brand-moss">Attachment-Focused</h3>
					<p class="mt-2 text-brand-ink/80">Strengthening the parent-child bond is at the heart of everything we do.</p>
				</div>
				<div>
					<h3 class="text-2xl font-serif text-brand-moss">Trauma-Responsive</h3>
					<p class="mt-2 text-brand-ink/80">Creating a safe space that acknowledges and honors past experiences.</p>
				</div>
				<div>
					<h3 class="text-serif text-2xl font-bold text-brand-moss">Evidence-Based</h3>
					<p class="mt-2 text-brand-ink/80">Utilizing proven therapeutic models to ensure the highest quality of care.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>