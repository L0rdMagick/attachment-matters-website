---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="Contact Family Trust Therapy | Durango & Cortez, CO" 
    description="Schedule a consultation with Genevieve Giddings, LCSW. Contact our Durango therapy office today to start your family's healing journey."
    keywords="contact child therapist Durango, book family therapist Cortez, Durango CO therapist contact, family counseling Colorado">

    <section class="container mx-auto px-6 py-20">
        <div class="grid lg:grid-cols-12 gap-12 md:gap-16 items-start max-w-6xl mx-auto">
            
            <!-- Left Column: Context, Phone Box, and Image -->
            <div class="lg:col-span-5 space-y-8">
                <div>
                    <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-ink leading-tight">
                        Ready to Take the Next Step?
                    </h1>
                    <p class="mt-4 text-lg text-brand-ink/80 leading-relaxed">
                        I am currently accepting a limited number of new clients. The best way to begin is to call me directly or complete this secure form to schedule a complimentary consultation.
                    </p>
                </div>

                <!-- Phone Box -->
                <div class="bg-brand-sandstone/70 border border-brand-sandstone rounded-3xl p-6 sm:p-8">
                    <p class="font-semibold text-sm uppercase tracking-wider text-brand-moss">
                        Schedule directly by phone:
                    </p>
                    <a 
                        href="tel:505-920-6351" 
                        class="mt-3 block text-3xl sm:text-4xl font-serif font-bold text-brand-terracotta hover:text-brand-moss transition-colors duration-300"
                    >
                        (505) 920-6351
                    </a>
                    <p class="mt-3 text-xs text-brand-ink/60 leading-normal">
                        Calls are typically returned within 24–48 business hours.
                    </p>
                </div>

                <!-- Calm Stone Image -->
                <div class="hidden lg:block">
                    <img 
                        src="/images/zen-stones-mental-wellbeing-durango.png" 
                        alt="Serene stacked stones representing peace and mental well-being in family therapy" 
                        class="rounded-3xl shadow-lg w-full h-64 object-cover"
                    >
                </div>
            </div>

            <!-- Right Column: Contact Form -->
            <div class="lg:col-span-7 bg-white rounded-3xl p-8 md:p-10 border border-brand-sandstone shadow-xl">
                <h2 class="text-2xl font-serif font-bold text-brand-ink mb-6">
                    Submit an Inquiry
                </h2>

                <!-- Status Message Display -->
                <div 
                    id="status-message" 
                    class="hidden p-4 mb-6 rounded-xl text-sm font-semibold"
                >
                </div>

                <form id="contact-form" class="space-y-6">
                    
                    <!-- Name Field -->
                    <div>
                        <label for="name" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                            First & Last Name <span class="text-brand-terracotta">*</span>
                        </label>
                        <input 
                            type="text" 
                            id="name" 
                            name="name" 
                            required 
                            class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base"
                            placeholder="Your name"
                        >
                    </div>

                    <!-- Contact Details Row -->
                    <div class="grid sm:grid-cols-2 gap-6">
                        <!-- Email -->
                        <div>
                            <label for="email" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                                Email Address <span class="text-brand-terracotta">*</span>
                            </label>
                            <input 
                                type="email" 
                                id="email" 
                                name="email" 
                                required 
                                class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base"
                                placeholder="name@example.com"
                            >
                        </div>
                        
                        <!-- Phone -->
                        <div>
                            <label for="phone" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                                Phone Number <span class="text-brand-terracotta">*</span>
                            </label>
                            <input 
                                type="tel" 
                                id="phone" 
                                name="phone" 
                                required 
                                class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base"
                                placeholder="(505) 000-0000"
                            >
                        </div>
                    </div>

                    <!-- Dropdowns Row -->
                    <div class="grid sm:grid-cols-2 gap-6">
                        <!-- Seeking For -->
                        <div>
                            <label for="seekingFor" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                                Who is seeking services? <span class="text-brand-terracotta">*</span>
                            </label>
                            <select 
                                id="seekingFor" 
                                name="seekingFor" 
                                required 
                                class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base cursor-pointer"
                            >
                                <option value="" disabled selected>Select one...</option>
                                <option value="Myself">Myself (Adult Individual)</option>
                                <option value="My child">My Child (Child/Adolescent)</option>
                                <option value="My family">My Family (Intensive Services)</option>
                                <option value="Other">Other / Legal Professional</option>
                            </select>
                        </div>

                        <!-- Preferred Contact Method -->
                        <div>
                            <label for="contactMethod" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                                Preferred Contact Method <span class="text-brand-terracotta">*</span>
                            </label>
                            <select 
                                id="contactMethod" 
                                name="contactMethod" 
                                required 
                                class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base cursor-pointer"
                            >
                                <option value="" disabled selected>Select preference...</option>
                                <option value="email">Email</option>
                                <option value="phone">Phone Call</option>
                                <option value="text">Text Message</option>
                            </select>
                        </div>
                    </div>

                    <!-- How did you hear about us -->
                    <div>
                        <label for="referral" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                            How did you hear about us?
                        </label>
                        <input 
                            type="text" 
                            id="referral" 
                            name="referral" 
                            class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base"
                            placeholder="e.g., attorney, therapist, search engine"
                        >
                    </div>

                    <!-- Message Field -->
                    <div>
                        <label for="message" class="block text-sm font-bold text-brand-ink/85 mb-1.5">
                            Briefly describe what you are seeking support with
                        </label>
                        <textarea 
                            id="message" 
                            name="message" 
                            rows="4" 
                            class="w-full px-4 py-3 bg-brand-linen/25 border border-brand-sandstone rounded-xl focus:outline-none focus:border-brand-terracotta focus:ring-1 focus:ring-brand-terracotta transition-colors text-brand-ink text-base resize-none"
                            placeholder="Reason for contact..."
                        ></textarea>
                        <p class="text-xs text-brand-ink/50 mt-2 leading-relaxed">
                            <strong>Note on Privacy:</strong> To protect your clinical privacy and ensure HIPAA compliance, please do not include highly sensitive clinical or medical details in this form. We can discuss these during your phone consultation.
                        </p>
                    </div>

                    <!-- Submit Button -->
                    <div>
                        <button 
                            type="submit" 
                            id="submit-btn"
                            class="w-full bg-brand-terracotta text-white font-bold text-lg py-4 px-6 rounded-full shadow hover:bg-brand-moss transition-colors duration-300 flex items-center justify-center gap-3 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                            <!-- Spinner Icon (Hidden by default) -->
                            <svg id="submit-spinner" class="animate-spin h-5 w-5 text-white hidden" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span id="submit-text">Send Inquiry</span>
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </section>
</Layout>

<script>
    // Client-side JavaScript to submit the form using AJAX (fetch)
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const statusMessage = document.getElementById('status-message');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');

    if (form && statusMessage && submitBtn && submitText && submitSpinner) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // Clear previous status messages
            statusMessage.classList.add('hidden');
            statusMessage.classList.remove(
                'bg-red-50', 'text-red-800', 'border-red-200',
                'bg-green-50', 'text-green-800', 'border-green-200'
            );
            statusMessage.textContent = '';
            
            // Set loading state
            submitBtn.disabled = true;
            submitText.textContent = 'Sending Message...';
            submitSpinner.classList.remove('hidden');

            const formData = new FormData(form);

            try {
                const response = await fetch('/api/contact', {
                    method: 'POST',
                    body: formData,
                });

                const result = await response.json();

                if (response.ok) {
                    // Success handling
                    statusMessage.textContent = 'Thank you! Your message has been sent successfully. We will get back to you soon.';
                    statusMessage.classList.remove('hidden');
                    statusMessage.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200');
                    form.reset();
                } else {
                    // Server error handling
                    statusMessage.textContent = result.error || 'Something went wrong. Please try again.';
                    statusMessage.classList.remove('hidden');
                    statusMessage.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
                }
            } catch (error) {
                console.error('Submission error:', error);
                statusMessage.textContent = 'A network error occurred. Please check your connection and try again.';
                statusMessage.classList.remove('hidden');
                statusMessage.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
            } finally {
                // Reset loading state
                submitBtn.disabled = false;
                submitText.textContent = 'Send Inquiry';
                submitSpinner.classList.add('hidden');
            }
        });
    }
</script>