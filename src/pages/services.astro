---
// src/pages/services.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="Therapeutic Services | Family Trust Therapy Durango" 
    description="Specialized child and family therapy services in Southwest Colorado, including intensive family-based therapy, court-involved assessments, and parent workshops."
    keywords="intensive family therapy Durango, family assessments Colorado, parenting workshops Cortez CO, therapeutic supervised visitation Durango, co-parenting therapist">
	<div class="bg-brand-sandstone">
		<section class="container mx-auto px-6 py-24">
			<div class="text-center max-w-3xl mx-auto">
				<h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-ink">Specialized Therapeutic Services</h1>
				<p class="mt-4 text-xl text-brand-ink/80">Our services are tailored to address challenges in complex family systems, serving clients in Durango, Cortez, and surrounding Southwest Colorado communities.</p>
			</div>

			<div class="mt-20 space-y-20">
				<!-- Service 1 -->
				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div>
						<img src="/images/intensive-family-therapy-colorado.png" alt="Parent and child connecting deeply during intensive family therapy session" class="rounded-3xl shadow-xl w-full h-full object-cover">
					</div>
					<div>
						<h2 class="text-3xl font-serif font-bold text-brand-moss">Intensive Family-Based Services</h2>
						<p class="mt-4 text-brand-ink/80">For families in La Plata and Montezuma counties seeking to rebuild bonds, improve caregiver attunement, and resolve childhood behavioral or emotional challenges.</p>
					</div>
				</div>
				<!-- Service 2 -->
				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div class="md:order-last">
						<img src="/images/family-attachment-co-parenting-assessment-co.png" alt="Professional custody and family functioning assessment documents" class="rounded-3xl shadow-xl w-full h-full object-cover">
					</div>
					<div>
						<h2 class="text-3xl font-serif font-bold text-brand-moss">Assessments for Legal Professionals</h2>
						<p class="mt-4 text-brand-ink/80">Objective, comprehensive evaluations for Colorado family courts in areas of family functioning, attachment, and co-parenting. Specialized therapeutic supervised visitation is also offered.</p>
					</div>
				</div>
				<!-- Service 3 -->
				<div class="grid md:grid-cols-2 gap-12 items-center">
					<div>
						<img src="/images/parent-education-workshop-cortez-co.png" alt="Parents collaborating and learning during a community parenting education workshop" class="rounded-3xl shadow-xl w-full h-full object-cover">
					</div>
					<div>
						<h2 class="text-3xl font-serif font-bold text-brand-moss">Workshops & Parent Education</h2>
						<p class="mt-4 text-brand-ink/80">Tailored workshops and parenting classes for community organizations, schools, and clinics looking to build strong caregiver capacity in the Four Corners region.</p>
					</div>
				</div>
			</div>
		</section>
	</div>
</Layout>