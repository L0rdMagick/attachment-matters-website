---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="About Genevieve Giddings, LCSW | Family Trust Therapy" 
    description="Genevieve Giddings, LCSW, is an attachment-focused, trauma-responsive child and family therapist in Durango, CO with 16 years of clinical experience."
    keywords="Genevieve Giddings LCSW, child therapist Durango CO, family counselor Durango, play therapy Durango, Southwest Colorado mental health">
    
    <section class="container mx-auto px-6 py-24">
		<div class="text-center max-w-3xl mx-auto animate-fade-in-up">
			<h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-ink">A Trusted Therapist for Children and Families</h1>
			<p class="mt-4 text-xl text-brand-ink/80">With 16 years of clinical experience, I bring a depth of expertise and a reputation for excellence to my work with families in Durango, Cortez, and across Southwest Colorado.</p>
		</div>
		<div class="mt-16 max-w-5xl mx-auto animate-fade-in-up-delay">
			<img src="/images/durango-colorado-family-therapy-office.png" alt="Warm, welcoming, and professional family therapy office in Durango, Colorado" class="rounded-3xl shadow-2xl w-full h-96 object-cover">
		</div>
	</section>

	<section class="bg-brand-sandstone py-24">
		<div class="container mx-auto px-6">
			<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center max-w-5xl mx-auto">
				<div class="reveal">
					<h2 class="text-3xl font-serif font-bold text-brand-ink">My Core Beliefs</h2>
					<ul class="mt-6 space-y-4 text-brand-ink/90">
						<li class="flex items-start"><span class="text-brand-terracotta font-bold mr-3 mt-1">✓</span><span>Every family has the capacity for growth and healing.</span></li>
						<li class="flex items-start"><span class="text-brand-terracotta font-bold mr-3 mt-1">✓</span><span>Safety and trust are the non-negotiable foundation of therapy.</span></li>
						<li class="flex items-start"><span class="text-brand-terracotta font-bold mr-3 mt-1">✓</span><span>A child-centered focus ultimately benefits the entire family system.</span></li>
					</ul>
				</div>
				<div class="reveal delay-200">
					<img src="/images/family-growth-healing-therapy-durango.jpg" alt="Caring hands nurturing a plant, symbolizing growth and healing in child therapy" class="rounded-3xl shadow-xl w-full h-full object-cover">
				</div>
			</div>
		</div>
	</section>
</Layout>